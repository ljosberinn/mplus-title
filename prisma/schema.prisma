generator client {
  provider = "prisma-client"
  output   = "./generated/prisma"
}

datasource db {
  provider = "mysql"
}

model History {
  timestamp   Int
  id          Int      @id @default(autoincrement())
  faction     Factions
  region      Regions
  customRank  Int
  customScore Float
  rioRank     Int
  rioScore    Float

  // read path filters `region = ? AND timestamp BETWEEN ? AND ?` ordered by
  // timestamp; without this every query full-scans the table.
  @@index([region, timestamp])
}

model CrossFactionHistory {
  id            Int     @id @default(autoincrement())
  timestamp     Int
  region        Regions
  score         Float
  rank          Int
  score100      Float   @default(0)
  rank100       Int     @default(0)

  // primary read path: `region = ? AND timestamp BETWEEN ? AND ?` ordered by
  // timestamp (loadDataForRegion + the cron's distinct-by-region lookup).
  @@index([region, timestamp])
}

model Extrapolation {
  id          Int    @id @default(autoincrement())
  estimatedAt Int
  timestamp   Int
  region      Regions
  score       Float

  // loadExtrapolationHistoryForSeason: `region = ? AND timestamp BETWEEN ? AND ?`.
  @@index([region, timestamp])
}

enum Factions {
  horde
  alliance
}

enum Regions {
  EU
  KR
  TW
  US
  CN
}

model DungeonHistory {
  id        Int    @id @default(autoincrement())
  timestamp Int
  slug      String
  keyLevel  Int

  // loadRecordsForSeason: `timestamp BETWEEN ? AND ? AND keyLevel >= 12`
  // ordered by timestamp.
  @@index([timestamp, keyLevel])
}
